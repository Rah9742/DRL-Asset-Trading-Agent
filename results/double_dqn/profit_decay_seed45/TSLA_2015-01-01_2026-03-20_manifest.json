{
  "config": {
    "data": {
      "provider": "yfinance",
      "ticker": "TSLA",
      "start_date": "2015-01-01",
      "end_date": "2026-03-20",
      "interval": "1d"
    },
    "features": {
      "sentiment_variant": "decay",
      "state_mode": "price_sentiment",
      "include_returns": true,
      "include_log_returns": true,
      "include_momentum": true,
      "include_volatility": true,
      "include_rsi": true,
      "include_cyclical_time_features": true,
      "lookback_window": 14,
      "sentiment_lag_days": 1,
      "sentiment_short_window": 3,
      "sentiment_long_window": 7,
      "sentiment_fill_value": 0.0,
      "sentiment_imputation_mode": "decay",
      "sentiment_decay_rate": 0.25
    },
    "environment": {
      "initial_cash": 10000.0,
      "transaction_cost": 0.001,
      "reward_mode": "profit",
      "annualization_factor": 252,
      "differential_sharpe_eta": 0.005,
      "differential_sharpe_eta_candidates": [
        0.001,
        0.005,
        0.01
      ],
      "differential_sharpe_epsilon": 1e-08,
      "differential_sharpe_warmup_steps": 20,
      "differential_sharpe_min_variance": 1e-06
    },
    "splits": {
      "train_end": "2020-12-31",
      "validation_end": "2024-03-20",
      "test_end": "2026-03-20"
    },
    "experiment": {
      "random_seed": 45,
      "seed_values": [
        42,
        43,
        44,
        45,
        46
      ]
    },
    "rl": {
      "algorithm": "double_dqn",
      "hidden_dim": 128,
      "learning_rate": 0.0001,
      "weight_decay": 0.0,
      "gamma": 0.99,
      "batch_size": 128,
      "buffer_capacity": 25000,
      "target_update_frequency": 250,
      "training_episodes": 50,
      "warmup_steps": 250,
      "epsilon_start": 1.0,
      "epsilon_end": 0.05,
      "epsilon_decay_steps": 5000,
      "validation_metric": "sharpe_ratio",
      "early_stopping_patience": 10,
      "early_stopping_min_delta": 0.0,
      "checkpoint_dir": "checkpoints/double_dqn",
      "results_dir": "results/double_dqn",
      "gradient_clip_norm": 1.0,
      "device": "cpu",
      "log_every_episodes": 5
    }
  },
  "dataset_name": "price_sentiment_decay",
  "run_name": "profit_decay_seed45",
  "scaler_path": "results/double_dqn/profit_decay_seed45/TSLA_2015-01-01_2026-03-20_feature_scaler.json",
  "feature_columns": [
    "return_1",
    "log_return_1",
    "momentum_14",
    "volatility_14",
    "rsi_14",
    "day_of_week_sin",
    "day_of_week_cos",
    "day_of_year_sin",
    "day_of_year_cos",
    "volume_change_1",
    "news_count",
    "mean_ticker_sentiment",
    "mean_ticker_relevance",
    "sentiment_std",
    "days_since_last_news",
    "sentiment_mean_3",
    "sentiment_mean_7",
    "sentiment_diff_1",
    "sentiment_window_spread_3_7"
  ],
  "feature_scaling_fit_split": "train",
  "validation_selection_metric": "sharpe_ratio",
  "early_stopping_patience": 10,
  "early_stopping_min_delta": 0.0
}