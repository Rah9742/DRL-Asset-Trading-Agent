{
  "config": {
    "data": {
      "provider": "yfinance",
      "ticker": "AAPL",
      "start_date": "2015-01-01",
      "end_date": "2024-12-31",
      "interval": "1d"
    },
    "features": {
      "sentiment_variant": "decay",
      "state_mode": "price_sentiment",
      "include_returns": true,
      "include_log_returns": true,
      "include_momentum": true,
      "include_volatility": true,
      "include_rsi": true,
      "lookback_window": 14,
      "sentiment_lag_days": 1,
      "sentiment_fill_value": 0.0,
      "sentiment_imputation_mode": "decay",
      "sentiment_decay_rate": 0.25
    },
    "environment": {
      "initial_cash": 10000.0,
      "transaction_cost": 0.001,
      "reward_mode": "profit",
      "annualization_factor": 252,
      "differential_sharpe_eta": 0.005,
      "differential_sharpe_eta_candidates": [
        0.001,
        0.005,
        0.01
      ],
      "differential_sharpe_epsilon": 1e-08,
      "differential_sharpe_warmup_steps": 20,
      "differential_sharpe_min_variance": 1e-06
    },
    "splits": {
      "train_end": "2020-12-31",
      "validation_end": "2022-12-31",
      "test_end": "2024-12-31"
    },
    "experiment": {
      "random_seed": 42,
      "seed_values": [
        42
      ]
    },
    "rl": {
      "algorithm": "double_dqn",
      "hidden_dim": 128,
      "learning_rate": 0.0001,
      "gamma": 0.99,
      "batch_size": 128,
      "buffer_capacity": 25000,
      "target_update_frequency": 250,
      "training_episodes": 50,
      "warmup_steps": 250,
      "epsilon_start": 1.0,
      "epsilon_end": 0.05,
      "epsilon_decay_steps": 5000,
      "validation_metric": "sharpe_ratio",
      "checkpoint_dir": "checkpoints/double_dqn",
      "results_dir": "results/double_dqn",
      "gradient_clip_norm": 1.0,
      "device": "cpu",
      "log_every_episodes": 5
    }
  },
  "dataset_name": "augmented",
  "run_name": "profit_decay_seed42",
  "scaler_path": "results/double_dqn/profit_decay_seed42/AAPL_2015-01-01_2024-12-31_feature_scaler.json"
}